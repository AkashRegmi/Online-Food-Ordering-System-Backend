doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title OTP Verification

    style.
      body {
        margin: 0;
        padding: 0;
        background: #f4f6f9;
        font-family: Arial, Helvetica, sans-serif;
      }

      .container {
        max-width: 500px;
        margin: 50px auto;
        background: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
      }

      .header {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        padding: 20px;
        text-align: center;
        color: white;
      }

      .header h1 {
        margin: 0;
        font-size: 22px;
      }

      .content {
        padding: 30px;
        text-align: center;
        color: #333;
      }

      .content p {
        font-size: 15px;
        margin-bottom: 20px;
      }

      .otp-box {
        display: inline-block;
        padding: 15px 25px;
        font-size: 28px;
        letter-spacing: 6px;
        font-weight: bold;
        color: #4f46e5;
        background: #f1f5ff;
        border-radius: 8px;
        margin: 20px 0;
      }

      .footer {
        font-size: 12px;
        color: #777;
        text-align: center;
        padding: 15px;
        border-top: 1px solid #eee;
      }

      .warning {
        font-size: 12px;
        color: #ef4444;
        margin-top: 10px;
      }

  body
    .container
      .header
        h1 OTP Verification

      .content
        p Hello #{name},
        p Use the following OTP to complete your verification:

        .otp-box #{otp}

        p This OTP is valid for
          b 5 minutes

        p.warning Do not share this OTP with anyone.

      .footer
        p © #{new Date().getFullYear()} Akash Regmi. All rights reserved.